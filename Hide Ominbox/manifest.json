{
  "manifest_version": 3,
  "name": "Hide Chrome Omnibox Suggestions (Best Effort)",
  "description": "Blocks remote suggest endpoints and disables server-side suggestions. Hides Google Search page suggestion UI.",
  "version": "1.0.6",
  "permissions": ["privacy", "declarativeNetRequest", "storage"],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.google.co.kr/*",
    "*://suggestqueries.google.com/*"
  ],
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "Toggle server suggestions",
    "default_icon": { "16": "icons/16.png", "32": "icons/32.png" },
    "default_popup": "popup.html"
  },
  "background": { "service_worker": "service_worker.js" },
  "declarative_net_request": {
    "rule_resources": [{ "id": "rules", "enabled": true, "path": "rules.json" }]
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/*", "https://www.google.co.kr/*"],
      "exclude_matches": ["https://accounts.google.com/*"],
      "run_at": "document_start",
      "css": ["hide.css"],
      "js": ["content_script.js"]
    }
  ]
}
